{
  "description": "HTTP request rate, latency, error rate, and logs for all GitFlow Analyzer services",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(flask_http_request_total{namespace=\"gitflow-analyzer\", service=~\"$service\"}[5m])) by (service)",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket{namespace=\"gitflow-analyzer\", service=~\"$service\"}[5m])) by (service, le))",
          "legendFormat": "p95 {{ service }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(flask_http_request_duration_seconds_bucket{namespace=\"gitflow-analyzer\", service=~\"$service\"}[5m])) by (service, le))",
          "legendFormat": "p50 {{ service }}",
          "refId": "B"
        }
      ],
      "title": "Request Latency (p95 / p50)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(flask_http_request_total{namespace=\"gitflow-analyzer\", service=~\"$service\", status=~\"[45]..\"}[5m])) by (service) / sum(rate(flask_http_request_total{namespace=\"gitflow-analyzer\", service=~\"$service\"}[5m])) by (service)",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ],
      "title": "Error Rate (4xx + 5xx)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 15 },
      "id": 4,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{namespace=\"gitflow-analyzer\", container=~\"$service\"}",
          "refId": "A"
        }
      ],
      "title": "Application Logs",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["gitflow", "application"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(flask_http_request_total{namespace=\"gitflow-analyzer\"}, service)",
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "query": {
          "query": "label_values(flask_http_request_total{namespace=\"gitflow-analyzer\"}, service)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "GitFlow Analyzer — Application",
  "uid": "gitflow-app"
}
